# ============================================================================
# LABORIT COPILOT API - Environment Configuration
# ============================================================================
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# For Render deployment: Set these as "Environment" variables in dashboard
# ============================================================================

# -------- DATABASE CONFIGURATION --------

# Option 1: Single connection string (takes priority)
# Format: mysql+pymysql://user:password@host:3306/database
# For Render MySQL: mysql+pymysql://user:pass@render_host:3306/laborit_db
# For PlanetScale: mysql+pymysql://user:pass@pscale_host/database?ssl_verify_cert=true&ssl_verify_identity=true
DATABASE_URL=

# Option 2: Individual connection vars (used if DATABASE_URL not set)
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306
DB_NAME=laborit_db

# -------- REDIS CACHE CONFIGURATION --------

# Cache backend: 'redis' or 'inmemory' (defaults to 'inmemory' if not set)
CACHE_BACKEND=redis

# Redis connection string
# Format: redis://:[password]@host:port/[db]
# For Render Redis: redis://:password@render_host:port
# For Redis Cloud: redis://:password@host:port
REDIS_URL=

# Cache key prefix (optional)
CACHE_PREFIX=laborit

# Cache TTL in seconds
RESPONSE_CACHE_TTL=3600
DATA_CACHE_TTL=1800

# -------- API SECURITY --------

# Optional API key for protected endpoints (/api/copilot/question, /api/metrics)
# When set, all requests to protected endpoints require header:
#   X-API-Key: <API_KEY_VALUE>
# Generate with: openssl rand -hex 32
API_KEY=

# -------- SERVICE TIMEOUTS (milliseconds) --------

QUERY_TIMEOUT_MS=10000
DATA_TIMEOUT_MS=15000
LLM_TIMEOUT_MS=30000

# -------- LOGGING & ENVIRONMENT --------

# Environment: 'development', 'staging', or 'production'
ENVIRONMENT=production

# Log level: 'DEBUG', 'INFO', 'WARNING', 'ERROR', 'CRITICAL'
# Use INFO or higher in production (avoid DEBUG for security)
LOG_LEVEL=INFO

# -------- PORT (Render specific) --------

# Render sets this automatically, but can override
# Default: 8000
# PORT=8000

# ============================================================================
# RENDER DEPLOYMENT CHECKLIST
# ============================================================================
#
# Before deploying to Render:
#
# 1. DATABASE_URL
#    - [ ] Use Render MySQL OR external provider (PlanetScale, RDS, etc)
#    - [ ] Test connection: mysql -u user -p -h host
#
# 2. REDIS_URL
#    - [ ] Use Render Redis OR Redis Cloud
#    - [ ] Test connection: redis-cli ping
#
# 3. API_KEY
#    - [ ] Generate strong key: openssl rand -hex 32
#    - [ ] Share securely with authorized clients
#
# 4. TIMEOUTS
#    - [ ] Adjust based on your database/LLM response times
#    - [ ] Recommend: QUERY=10000, DATA=15000, LLM=30000
#
# 5. LOG_LEVEL
#    - [ ] Set to INFO or ERROR in production
#    - [ ] Never set to DEBUG in production (security risk)
#
# 6. Test post-deploy:
#    - [ ] curl https://your-app.onrender.com/api/health
#    - [ ] curl -H "X-API-Key: YOUR_KEY" https://your-app.onrender.com/api/metrics
#
# ============================================================================
