# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Option 1: single DSN (takes priority over individual vars below)
# DATABASE_URL=mysql+pymysql://user:password@host:3306/database

# Option 2: individual vars
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306
DB_NAME=northwind

# Optional API security for protected endpoints
# When set, requests to /api/copilot/question and /api/metrics require header:
# X-API-Key: <API_KEY>
API_KEY=

# Cache and runtime options
# CACHE_BACKEND=in-memory|redis
# REDIS_URL=redis://localhost:6379/0
# CACHE_PREFIX=laborit
